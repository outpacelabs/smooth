{
	"name": "@outpacelabs/squircle",
	"version": "0.1.0",
	"description": "Figma-style corner smoothing (Apple squircles) that keeps your corner radius. Path generator + React clip-path hook.",
	"keywords": [
		"squircle",
		"corner-smoothing",
		"border-radius",
		"figma",
		"superellipse",
		"clip-path",
		"react"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/outpacelabs/smooth.git",
		"directory": "packages/squircle"
	},
	"author": "Outpace Studios (https://outpacestudios.com)",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js",
			"require": "./dist/react.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "pnpm build && node test/properties.mjs",
		"prepublishOnly": "pnpm test"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.2.10",
		"react": "^19.2.4",
		"tsup": "^8.3.5",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
